<section id="contacto" class="py-20 px-6 bg-white">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-4">
        Contáctanos
      </h2>
      <p class="text-xl text-gray-600">
        Estamos listos para atenderte y resolver tus necesidades
      </p>
    </div>

    <!-- Técnicos Profesionales -->
    <div
      class="bg-linear-to-r from-orange-600 to-orange-500 rounded-2xl p-8 mb-12 text-white"
    >
      <h3 class="text-2xl font-bold mb-6 text-center">
        Nuestros Técnicos Especializados
      </h3>
      <div class="grid md:grid-cols-2 gap-8">
        <div
          class="bg-white/10 backdrop-blur rounded-xl p-6 hover:bg-white/20 transition-all"
        >
          <div class="flex items-center gap-4 mb-3">
            <div
              class="w-16 h-16 bg-white rounded-full flex items-center justify-center text-4xl"
            >
              👨‍🔧
            </div>
            <div>
              <h4 class="text-xl font-bold">Farid Penagos</h4>
              <p class="text-orange-100">Técnico Especialista</p>
            </div>
          </div>
          <a
            href="https://wa.me/573203748886?text=Hola%20Farin,%20necesito%20información%20sobre%20sus%20servicios"
            target="_blank"
            class="flex items-center gap-2 text-lg font-semibold hover:text-green-300 transition-colors"
          >
            <span class="text-2xl">📱</span>
            <span>3203748886</span>
          </a>
        </div>

        <div
          class="bg-white/10 backdrop-blur rounded-xl p-6 hover:bg-white/20 transition-all"
        >
          <div class="flex items-center gap-4 mb-3">
            <div
              class="w-16 h-16 bg-white rounded-full flex items-center justify-center text-4xl"
            >
              👩‍🔧
            </div>
            <div>
              <h4 class="text-xl font-bold">Nohemi Velásquez</h4>
              <p class="text-orange-100">Técnica Especialista</p>
            </div>
          </div>
          <a
            href="https://wa.me/573142610333?text=Hola%20Nohemi,%20necesito%20información%20sobre%20sus%20servicios"
            target="_blank"
            class="flex items-center gap-2 text-lg font-semibold hover:text-green-300 transition-colors"
          >
            <span class="text-2xl">📱</span>
            <span>314 261 0333</span>
          </a>
        </div>
      </div>
    </div>

    <!-- Información de contacto -->
    <div class="grid md:grid-cols-3 gap-8 mb-12">
      <div
        class="bg-gray-50 p-8 rounded-xl hover:bg-orange-600 hover:text-white transition-all duration-300 text-center group"
      >
        <div class="text-5xl mb-4">📍</div>
        <h3 class="text-xl font-bold mb-2">Ubicación</h3>
        <p class="text-gray-600 group-hover:text-white">
          Carrera 28 No. 67-89<br />
          Barrio 7 de Agosto<br />
          Bogotá, Colombia
        </p>
      </div>

      <div
        class="bg-gray-50 p-8 rounded-xl hover:bg-orange-600 hover:text-white transition-all duration-300 text-center group"
      >
        <div class="text-5xl mb-4">⏰</div>
        <h3 class="text-xl font-bold mb-2">Horario</h3>
        <p class="text-gray-600 group-hover:text-white">
          Lunes a Viernes: 7:00 a.m. - 5:00 p.m.<br />
          Sábados: 7:00 a.m. - 4:00 p.m.<br />
          Domingos: Cerrado
        </p>
      </div>

      <div
        class="bg-gray-50 p-8 rounded-xl hover:bg-orange-600 hover:text-white transition-all duration-300 text-center group"
      >
        <div class="text-5xl mb-4">🛠️</div>
        <h3 class="text-xl font-bold mb-2">Especialidad</h3>
        <p class="text-gray-600 group-hover:text-white">
          Aire Acondicionado<br />
          Radiadores
        </p>
      </div>
    </div>

    <!-- Botones de WhatsApp -->
    <div class="text-center space-y-4">
      <p class="text-gray-700 text-lg font-semibold mb-4">
        Contáctanos directamente por WhatsApp:
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="https://wa.me/573203748886?text=Hola,%20me%20gustaría%20solicitar%20información%20sobre%20sus%20servicios"
          target="_blank"
          class="inline-flex items-center justify-center gap-3 bg-green-500 hover:bg-green-600 text-white font-bold py-4 px-8 rounded-full text-lg transition-all transform hover:scale-105 shadow-lg"
        >
          <span class="text-2xl">💬</span>
          <span>WhatsApp Farid</span>
        </a>
        <a
          href="https://wa.me/573142610333?text=Hola,%20me%20gustaría%20solicitar%20información%20sobre%20sus%20servicios"
          target="_blank"
          class="inline-flex items-center justify-center gap-3 bg-green-500 hover:bg-green-600 text-white font-bold py-4 px-8 rounded-full text-lg transition-all transform hover:scale-105 shadow-lg"
        >
          <span class="text-2xl">💬</span>
          <span>WhatsApp Nohemi</span>
        </a>
      </div>
    </div>
  </div>
</section>
