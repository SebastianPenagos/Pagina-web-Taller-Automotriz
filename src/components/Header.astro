---

---

<header
  class="fixed top-0 w-full bg-gradient-to-r from-gray-900 to-gray-800 text-white z-50 shadow-xl"
>
  <nav class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
    <div class="flex items-center gap-3">
      <div class="text-orange-600 text-3xl">🔧</div>
      <div>
        <div
          class="text-xl md:text-2xl font-extrabold text-orange-600 uppercase tracking-wide leading-tight"
        >
          DIS AIRE ACONDICIONADO
        </div>
        <div class="text-xs md:text-sm text-gray-300 font-medium">
          Y RADIADORES NV
        </div>
      </div>
    </div>

    <!-- Desktop Menu -->
    <ul class="hidden md:flex gap-8">
      <li>
        <a
          href="#servicios"
          class="hover:text-orange-600 transition-colors font-medium"
          >Servicios</a>
      </li>
      <li>
        <a
          href="#inventario"
          class="hover:text-orange-600 transition-colors font-medium"
          >Inventario</a>
      </li>
      <li>
        <a
          href="#repuestos"
          class="hover:text-orange-600 transition-colors font-medium"
          >Repuestos</a>
      </li>
      <li>
        <a
          href="#porque"
          class="hover:text-orange-600 transition-colors font-medium"
          >Nosotros</a>
      </li>
      <li>
        <a
          href="#ubicacion"
          class="hover:text-orange-600 transition-colors font-medium"
          >Ubicación</a>
      </li>
      <li>
        <a
          href="#contacto"
          class="hover:text-orange-600 transition-colors font-medium"
          >Contacto</a>
      </li>
    </ul>

    <!-- Mobile menu button -->
    <button
      type="button"
      id="mobile-menu-btn"
      class="md:hidden text-white focus:outline-none focus:text-orange-600 transition-colors p-2"
      aria-label="Abrir menú"
      aria-expanded="false"
    >
      <svg
        id="menu-icon"
        class="w-7 h-7"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu-content"
    class="hidden md:hidden bg-gray-800 border-t border-gray-700"
  >
    <ul class="px-6 py-4 space-y-3">
      <li>
        <a
          href="#servicios"
          class="mobile-link block py-3 hover:text-orange-600 hover:bg-gray-700 px-4 rounded-lg transition-colors text-lg"
        >
          📋 Servicios
        </a>
      </li>
      <li>
        <a
          href="#inventario"
          class="mobile-link block py-3 hover:text-orange-600 hover:bg-gray-700 px-4 rounded-lg transition-colors text-lg"
        >
          📦 Inventario
        </a>
      </li>
      <li>
        <a
          href="#repuestos"
          class="mobile-link block py-3 hover:text-orange-600 hover:bg-gray-700 px-4 rounded-lg transition-colors text-lg"
        >
          🔧 Repuestos
        </a>
      </li>
      <li>
        <a
          href="#porque"
          class="mobile-link block py-3 hover:text-orange-600 hover:bg-gray-700 px-4 rounded-lg transition-colors text-lg"
        >
          ⭐ Nosotros
        </a>
      </li>
      <li>
        <a
          href="#ubicacion"
          class="mobile-link block py-3 hover:text-orange-600 hover:bg-gray-700 px-4 rounded-lg transition-colors text-lg"
        >
          📍 Ubicación
        </a>
      </li>
      <li>
        <a
          href="#contacto"
          class="mobile-link block py-3 hover:text-orange-600 hover:bg-gray-700 px-4 rounded-lg transition-colors text-lg"
        >
          📞 Contacto
        </a>
      </li>
    </ul>
  </div>
</header>

<script is:inline>
  // Script inline para asegurar que funcione
  (function () {
    function initMobileMenu() {
      const btn = document.getElementById("mobile-menu-btn");
      const menu = document.getElementById("mobile-menu-content");
      const icon = document.getElementById("menu-icon");
      const links = document.querySelectorAll(".mobile-link");

      if (!btn || !menu || !icon) {
        console.error("Mobile menu elements not found");
        return;
      }

      // Toggle menú
      btn.addEventListener("click", function (e) {
        e.preventDefault();
        const isHidden = menu.classList.contains("hidden");

        if (isHidden) {
          menu.classList.remove("hidden");
          btn.setAttribute("aria-expanded", "true");
          // Cambiar a ícono X
          icon.innerHTML =
            '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>';
        } else {
          menu.classList.add("hidden");
          btn.setAttribute("aria-expanded", "false");
          // Cambiar a ícono hamburguesa
          icon.innerHTML =
            '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>';
        }
      });

      // Cerrar al hacer click en un enlace
      links.forEach(function (link) {
        link.addEventListener("click", function () {
          menu.classList.add("hidden");
          btn.setAttribute("aria-expanded", "false");
          icon.innerHTML =
            '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>';
        });
      });

      // Cerrar al hacer click fuera
      document.addEventListener("click", function (e) {
        if (!btn.contains(e.target) && !menu.contains(e.target)) {
          if (!menu.classList.contains("hidden")) {
            menu.classList.add("hidden");
            btn.setAttribute("aria-expanded", "false");
            icon.innerHTML =
              '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>';
          }
        }
      });
    }

    // Inicializar cuando el DOM esté listo
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initMobileMenu);
    } else {
      initMobileMenu();
    }
  })();
</script>

<style>
  /* Smooth scroll para los enlaces */
  html {
    scroll-behavior: smooth;
  }

  /* Asegurar que el menú móvil tenga la altura correcta */
  #mobile-menu-content {
    transition: all 0.3s ease-in-out;
  }
</style>
