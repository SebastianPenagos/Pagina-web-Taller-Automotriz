const categories = [...new Set(products.map((p) => p.category))];
---

<section id="inventario" class="py-20 px-6 bg-white">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-4">
        Nuestro Inventario
      </h2>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        Repuestos originales y de primera calidad disponibles en stock
      </p>
    </div>

    <!-- Filtros por categoría -->
    <div class="flex flex-wrap justify-center gap-3 mb-12">
      <button
        class="filter-btn active px-6 py-2 rounded-full bg-orange-600 text-white font-semibold transition-all hover:bg-orange-700 shadow-md"
        data-category="all"
      >
        Todos ({products.length})
      </button>
      {
        categories.map((category) => {
          const count = products.filter((p) => p.category === category).length;
          return (
            <button
              class="filter-btn px-6 py-2 rounded-full bg-gray-200 text-gray-700 font-semibold transition-all hover:bg-gray-300 shadow-md"
              data-category={category}
            >
              {category} ({count})
            </button>
          );
        })
      }
    </div>

    <!-- Grid de productos -->
    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6"
      id="products-grid"
    >
      {
        products.map((product) => (
          <div
            class="product-item bg-white rounded-xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 cursor-pointer group"
            data-category={product.category}
            data-product-id={product.id}
          >
            <div class="relative overflow-hidden h-64 bg-gradient-to-br from-gray-100 to-gray-200">
              <img
                src={product.image}
                alt={product.title}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                loading="lazy"
              />
              <div class="absolute top-2 right-2 bg-orange-600 text-white text-xs font-bold px-3 py-1 rounded-full">
                DISPONIBLE
              </div>
              <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end">
                <div class="p-4 text-white transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
                  <p class="text-sm font-medium">{product.description}</p>
                  <p class="text-xs mt-2 text-orange-300">Click para ampliar</p>
                </div>
              </div>
            </div>
            <div class="p-4">
              <p class="text-xs text-orange-600 font-semibold mb-1 uppercase tracking-wide">
                {product.category}
              </p>
              <h3 class="text-lg font-bold text-gray-900 group-hover:text-orange-600 transition-colors">
                {product.title}
              </h3>
            </div>
          </div>
        ))
      }
    </div>

    <!-- Mensaje cuando no hay resultados -->
    <div id="no-results" class="hidden text-center py-12">
      <div class="text-6xl mb-4">🔍</div>
      <p class="text-xl text-gray-600 mb-2">
        No se encontraron productos en esta categoría
      </p>
      <button
        class="text-orange-600 font-semibold hover:underline"
        id="reset-filter"
      >
        Ver todos los productos
      </button>
    </div>

    <!-- CTA -->
  
  </div>
</section>

<!-- Lightbox Modal -->
<div
  id="lightbox"
  class="fixed inset-0 bg-black/95 hidden items-center justify-center z-50 p-4"
>
  <button
    id="close-lightbox"
    class="absolute top-4 right-4 text-white text-5xl hover:text-orange-600 transition-colors w-12 h-12 flex items-center justify-center"
  >
    ×
  </button>

  <!-- Navegación -->
  <button
    id="prev-image"
    class="absolute left-4 top-1/2 -translate-y-1/2 text-white text-5xl hover:text-orange-600 transition-colors w-12 h-12 flex items-center justify-center bg-black/50 rounded-full"
  >
    ‹
  </button>
  <button
    id="next-image"
    class="absolute right-4 top-1/2 -translate-y-1/2 text-white text-5xl hover:text-orange-600 transition-colors w-12 h-12 flex items-center justify-center bg-black/50 rounded-full"
  >
    ›
  </button>

  <div class="max-w-6xl w-full">
    <img
      id="lightbox-img"
      src=""
      alt=""
      class="w-full h-auto max-h-[80vh] object-contain rounded-lg"
    />
    <div class="text-center mt-6 bg-black/60 rounded-lg p-6 backdrop-blur">
      <span
        id="lightbox-category"
        class="inline-block text-orange-500 text-sm font-semibold mb-2 px-3 py-1 bg-orange-500/20 rounded-full"
      ></span>
      <h3 id="lightbox-title" class="text-white text-3xl font-bold mb-3"></h3>
      <p id="lightbox-desc" class="text-gray-300 text-lg"></p>
      <div class="mt-4 text-sm text-gray-400">
        <span id="lightbox-counter"></span>
      </div>
    </div>
  </div>
</div>

<script>
  // Filtrado por categoría con tipos correctos
  const filterBtns = document.querySelectorAll(".filter-btn");
  const productItems = document.querySelectorAll(
    ".product-item",
  ) as NodeListOf<HTMLElement>;
  const noResults = document.getElementById("no-results");
  const resetFilterBtn = document.getElementById("reset-filter");

  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const category = btn.getAttribute("data-category");

      // Actualizar botones activos
      filterBtns.forEach((b) => {
        b.classList.remove("active", "bg-orange-600", "text-white");
        b.classList.add("bg-gray-200", "text-gray-700");
      });
      btn.classList.add("active", "bg-orange-600", "text-white");
      btn.classList.remove("bg-gray-200", "text-gray-700");

      // Filtrar productos
      let visibleCount = 0;
      productItems.forEach((item) => {
        if (
          category === "all" ||
          item.getAttribute("data-category") === category
        ) {
          item.style.display = "block";
          item.style.animation = "fadeIn 0.5s";
          visibleCount++;
        } else {
          item.style.display = "none";
        }
      });

      // Mostrar mensaje si no hay resultados
      if (visibleCount === 0) {
        noResults?.classList.remove("hidden");
      } else {
        noResults?.classList.add("hidden");
      }
    });
  });

  // Botón reset del filtro
  resetFilterBtn?.addEventListener("click", () => {
    const allBtn = document.querySelector(
      '[data-category="all"]',
    ) as HTMLElement;
    allBtn?.click();
  });

  // Lightbox con tipos correctos
  const lightbox = document.getElementById("lightbox");
  const lightboxImg = document.getElementById(
    "lightbox-img",
  ) as HTMLImageElement;
  const lightboxTitle = document.getElementById("lightbox-title");
  const lightboxCategory = document.getElementById("lightbox-category");
  const lightboxDesc = document.getElementById("lightbox-desc");
  const lightboxCounter = document.getElementById("lightbox-counter");
  const closeLightbox = document.getElementById("close-lightbox");
  const prevBtn = document.getElementById("prev-image");
  const nextBtn = document.getElementById("next-image");

  let currentIndex = 0;

  function getVisibleProducts(): HTMLElement[] {
    return Array.from(productItems).filter(
      (item) => item.style.display !== "none",
    );
  }

  function updateLightbox(index: number) {
    const visibleItems = getVisibleProducts();
    if (visibleItems.length === 0) return;

    currentIndex =
      ((index % visibleItems.length) + visibleItems.length) %
      visibleItems.length;
    const item = visibleItems[currentIndex];

    const img = item.querySelector("img") as HTMLImageElement;
    const title = item.querySelector("h3")?.textContent || "";
    const category = item.querySelector("p")?.textContent || "";
    const descElement = item.querySelector(".absolute p");
    const desc = descElement?.textContent || "";

    if (lightboxImg && img) lightboxImg.src = img.src;
    if (lightboxTitle) lightboxTitle.textContent = title;
    if (lightboxCategory) lightboxCategory.textContent = category;
    if (lightboxDesc) lightboxDesc.textContent = desc;
    if (lightboxCounter)
      lightboxCounter.textContent = `${currentIndex + 1} de ${visibleItems.length}`;
  }

  productItems.forEach((item) => {
    item.addEventListener("click", () => {
      const visibleItems = getVisibleProducts();
      currentIndex = visibleItems.indexOf(item);
      updateLightbox(currentIndex);
      lightbox?.classList.remove("hidden");
      lightbox?.classList.add("flex");
    });
  });

  closeLightbox?.addEventListener("click", () => {
    lightbox?.classList.add("hidden");
    lightbox?.classList.remove("flex");
  });

  prevBtn?.addEventListener("click", (e) => {
    e.stopPropagation();
    updateLightbox(currentIndex - 1);
  });

  nextBtn?.addEventListener("click", (e) => {
    e.stopPropagation();
    updateLightbox(currentIndex + 1);
  });

  // Cerrar con tecla ESC y navegar con flechas
  document.addEventListener("keydown", (e) => {
    if (lightbox && !lightbox.classList.contains("hidden")) {
      if (e.key === "Escape") {
        lightbox.classList.add("hidden");
        lightbox.classList.remove("flex");
      } else if (e.key === "ArrowLeft") {
        updateLightbox(currentIndex - 1);
      } else if (e.key === "ArrowRight") {
        updateLightbox(currentIndex + 1);
      }
    }
  });

  lightbox?.addEventListener("click", (e) => {
    if (e.target === lightbox) {
      lightbox.classList.add("hidden");
      lightbox.classList.remove("flex");
    }
  });
</script>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: scale(0.95);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  .product-item {
    animation: fadeIn 0.5s ease-out;
  }
</style>
