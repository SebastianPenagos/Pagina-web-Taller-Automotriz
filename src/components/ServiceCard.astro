---
interface Props {
  icon: string;
  title: string;
  description: string;
  features: string[];
}

const { icon, title, description, features } = Astro.props;
---

<div
  class="bg-white p-8 rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 border-2 border-transparent hover:border-orange-600 hover:-translate-y-2 service-card"
>
  <div
    class="w-20 h-20 bg-gradient-to-br from-orange-600 to-orange-500 rounded-2xl flex items-center justify-center text-5xl mb-6"
  >
    {icon}
  </div>

  <h3 class="text-2xl font-bold text-gray-900 mb-3">{title}</h3>

  <p class="text-gray-600 mb-4 leading-relaxed">{description}</p>

  <ul class="space-y-2">
    {
      features.map((feature) => (
        <li class="flex items-start">
          <span class="text-orange-600 font-bold mr-2">✓</span>
          <span class="text-gray-700">{feature}</span>
        </li>
      ))
    }
  </ul>
</div>

<style>
  .service-card {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.6s ease-out forwards;
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
