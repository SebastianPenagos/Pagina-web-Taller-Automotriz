---
import ServiceCard from "./ServiceCard.astro";
---

<section id="servicios" class="py-20 px-6 bg-white">
  <div class="max-w-7xl mx-auto pt-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-4">
        Nuestros Servicios
      </h2>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        Soluciones integrales para el sistema de refrigeración de tu vehículo
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      <ServiceCard
        icon="❄️"
        title="Aire Acondicionado"
        description="Servicio completo de aire acondicionado automotriz"
        features={[
          "Recarga de gas refrigerante",
          "Reparación de fugas",
          "Cambio de compresor",
          "Limpieza de sistema",
          "Mantenimiento preventivo",
        ]}
      />

      <ServiceCard
        icon="🌡️"
        title="Radiadores"
        description="Especialistas en sistemas de enfriamiento"
        features={[
          "Reparación de radiadores",
          "Cambio de radiadores",
          "Limpieza química",
          "Soldadura especializada",
          "Pruebas de presión",
          "Mantenimiento integral",
        ]}
      />

      <ServiceCard
        icon="⚙️"
        title="Mantenimiento"
        description="Prevención y cuidado de tu vehículo"
        features={[
          "Revisión de sistema de enfriamiento",
          "Inspección de mangueras",
          "Verificación de termostato",
          "Limpieza de condensador",
          "Diagnóstico completo",
        ]}
      />
    </div>
  </div>
</section>
